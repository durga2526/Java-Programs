import java.applet.Applet;
import java.awt.*;
import java.awt.event.*;

/* <applet code="TypingTutor" width=400 height=200></applet> */

public class TypingTutor extends Applet implements KeyListener {

    String text = "";

    public void init() {
        addKeyListener(this);
        setFocusable(true);
    }

    public void keyTyped(KeyEvent e) {
        text += e.getKeyChar();
        repaint();
    }

    public void keyPressed(KeyEvent e) {}
    public void keyReleased(KeyEvent e) {}

    public void paint(Graphics g) {
        g.drawString("Type Something:", 20, 50);
        g.drawString(text, 20, 80);
    }
}
