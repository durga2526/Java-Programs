class Vehicle {
    String fuelType() {
        return "Diesel";
    }
}

class Car extends Vehicle {
    @Override
    String fuelType() {
        return "Petrol";
    }
}

public class VehicleMain {
    public static void main(String[] args) {

        Vehicle v = new Car();
        System.out.println("Fuel Type: " + v.fuelType());
    }
}
