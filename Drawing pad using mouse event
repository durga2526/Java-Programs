import java.applet.Applet;
import java.awt.*;
import java.awt.event.*;

/* <applet code="DrawingPad" width=400 height=300></applet> */

public class DrawingPad extends Applet implements MouseMotionListener {

    int x, y;

    public void init() {
        addMouseMotionListener(this);
    }

    public void mouseDragged(MouseEvent e) {
        x = e.getX();
        y = e.getY();
        repaint();
    }

    public void mouseMoved(MouseEvent e) {}

    public void paint(Graphics g) {
        g.fillOval(x, y, 5, 5);
    }
}
