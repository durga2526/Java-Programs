import java.util.Scanner;
public class StudentResult {
    public static void main(String[] args) {
        Scanner sc = new Scanner(System.in);
        System.out.println("Enter mark for subject1:");
        int sub1=sc.nextInt();
        System.out.println("Enter mark for subject2:");
        int sub2=sc.nextInt();
        System.out.println("Enter mark for subject3:");
        int sub3=sc.nextInt();
        System.out.println("Enter mark for subject4:");
        int sub4=sc.nextInt();
        int total_marks=(sub1+sub2+sub3+sub4)/4;
        System.out.println("Total Marks: "+total_marks);
        int result=total_marks;
        if(result>=90) {
            System.out.println("Result: Distinction");
        }
        else ifif(result>=60) {
            System.out.println("Result: First Class");
        }
        else ifif(result>=50) {
            System.out.println("Result: Second Class");
        }
        else {
            System.out.println("Result: Fail");
        }
    }
}
